{% assign cat = data[0] %}
{% assign breed = cat.breeds[0] %}

<div class="layout" style="display: flex; flex-direction: row; height: 100%; gap: 12px; padding: 12px; align-items: center;">
  <div style="flex: 0 0 50%; display: flex; align-items: center; justify-content: center; height: 100%;">
    <img class="image-dither"
         src="{{ cat.url }}"
         style="max-width: 100%; max-height: 100%; object-fit: contain;" />
  </div>
  <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 8px; overflow: hidden;">
    {% if breed.name != blank %}
      <span class="label label--large">{{ breed.name }}</span>
      {% if breed.origin != blank %}
        <span class="label">📍 {{ breed.origin }}</span>
      {% endif %}
      {% if breed.life_span != blank %}
        <span class="label">⏳ {{ breed.life_span }} years</span>
      {% endif %}
      {% if breed.temperament != blank %}
        <span class="label" style="opacity: 0.7;">{{ breed.temperament | truncate: 60 }}</span>
      {% endif %}
    {% else %}
      <span class="label label--large">{{ cat.id }}</span>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  {% if breed.name != blank %}
    <span class="instance">{{ cat.id }}</span>
  {% endif %}
</div>

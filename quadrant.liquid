{% assign cat = data[0] %}
{% assign breed = cat.breeds[0] %}

<div class="layout layout--center" style="height: 100%; display: flex; align-items: center; justify-content: center; padding: 8px;">
  <img class="image-dither"
       src="{{ cat.url }}"
       style="max-width: 100%; max-height: 100%; object-fit: contain;" />
</div>

<div class="title_bar">
  {% if breed.name != blank %}
    <span class="title">{{ breed.name }}</span>
  {% else %}
    <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  {% endif %}
  <span class="instance">{{ cat.id }}</span>
</div>
